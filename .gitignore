# Dotfiles .gitignore

# OS and editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
.netrwhist

# Private configs (if any)
git/.gitconfig_local
bash/.bashrc_local
zsh/.zshrc_local
ssh/config
ssh/id_*
ssh/*.pem
ssh/*.key
ssh/*.pub

# Backup directory
backup/
.backup_dotfiles/
backups/
system-state/

# VS Code machine state
vscode/User/globalStorage/
vscode/User/workspaceStorage/
vscode/User/History/
vscode/User/Backups/

# Generated restore snapshots
snapshots/

# Build artifacts
*.o
*.a
*.so
*.out
solution
sol

# Logs
*.log

# Cache and temporary
.cache/
__pycache__/
*.pyc

# Node modules (if any)
node_modules/

# Virtual environments
venv/
env/
.env

# macOS
.AppleDouble
.LSOverride
._*

# Linux
.directory

# Temporary
tmp/
*.tmp

# Shell history and local state
.bash_history
.zsh_history
