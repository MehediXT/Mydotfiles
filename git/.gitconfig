[user]
    name = Your Name
    email = your.email@example.com

[core]
    editor = nvim
    pager = less -R
    autocrlf = input

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    unstage = reset HEAD --
    last = log -1 HEAD
    visual = log --graph --oneline --all
    amend = commit --amend --no-edit
    resolve-ours = checkout --ours
    resolve-theirs = checkout --theirs

[color]
    ui = true
    status = true
    branch = true
    diff = true

[init]
    defaultBranch = main

[pull]
    rebase = false

[help]
    autocorrect = 0

[grep]
    lineNumber = true
